# 환경 변수 가이드.
#
# 파일 우선순위 (Vite): .env.local > .env (둘 다 gitignored).
# 이 .env.local.example 만 git tracked — 새 멤버가 보고 본인 .env 를 만든다.

# === 백엔드 API ===
# 백엔드 context-path 가 /api 라 끝에 /api 까지 포함해야 함.
# 백엔드 도메인 api.logi.p-e.kr 가 안정 IP + 정상 cert 로 떠 있어 직접 호출이 기본 패턴.
# (옛 우회: vite proxy + EC2 IP 직접 + secure:false 는 도메인 살아나서 폐기.)
# 백엔드 OpenAPI/Swagger UI: https://api.logi.p-e.kr/api/swagger-ui/index.html
# 로컬 백엔드 띄울 때: VITE_API_URL=http://localhost:8080/api
VITE_API_URL=https://api.logi.p-e.kr/api

# === Google OAuth (랜딩 → 로그인) ===
# 백엔드 팀이 Google Console 에 등록한 client_id 와 같아야 함.
# redirect_uri 는 Google Console 에 정확히 등록된 값이어야 함.
# 현재 등록 정책: http://localhost:3000/auth/callback (백엔드 환경변수 GOOGLE_REDIRECT_URI 와 일치).
# client_secret 은 백엔드만 보유 — 프론트는 공개해도 되는 client_id 만 사용.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# === (선택) DEV 테스트 토큰 ===
# 백엔드 팀이 발급한 access JWT 를 받아 본인 .env 에 채우면, OAuth 안 거치고
# API 직접 호출 / DEV 빌드에서 빠르게 인증 상태 진입 가능.
# 만료되면 백엔드 팀에 새 토큰 요청. 시크릿이라 .env (gitignored) 에만 둘 것.
# VITE_DEV_TEST_ACCESS_TOKEN=eyJ...
